# .env にコピーして値を埋める。.env は絶対にコミットしないこと(.gitignore済み)
ANTHROPIC_API_KEY=

# 未設定時は phrase_generator.py 側のデフォルト(claude-sonnet-5)を使う
PHRASE_GEN_MODEL=

# src/tts_elevenlabs.py で使用
ELEVENLABS_API_KEY=

# フォントパス(環境によって異なる)。未設定ならデフォルトパスを使用する
# Linux: /usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
# macOS: /System/Library/Fonts/Helvetica.ttc または brew install --cask font-noto-sans-cjk-jp 後に設定
EN_FONT_PATH=

# Linux: /usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc
# macOS: /Library/Fonts/NotoSansCJK-Bold.ttc (要インストール) または /System/Library/Fonts/AppleSDGothicNeo.ttc
JP_FONT_PATH=

